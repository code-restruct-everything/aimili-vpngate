# /etc/default/vpngate-socks-auth
# Loaded by:
# - /etc/systemd/system/vpngate-socks-auth.service
# - /etc/systemd/system/vpngate-socks-auth@.service
#
# NOTE:
# - Leave SOCKS_ALLOWED_USERS empty to allow all system users.
# - Set SOCKS_ALLOWED_USERS=worker (or comma-separated list) to restrict users.
# - For multi-instance mode, put common values here and override per-instance in:
#   /etc/default/vpngate-socks-auth-<instance>

# SOCKS bind
SOCKS_HOST=0.0.0.0
SOCKS_PORT=7928

# Restrict login users (empty = all system users)
SOCKS_ALLOWED_USERS=

# VPNGate scanning / probing
MAX_SCAN_ROWS=300
TEST_CANDIDATES=8
OPENVPN_TEST_TIMEOUT_SECONDS=15

# Optional country filters (empty = no country restriction)
# Example: VPNGATE_COUNTRY=Japan
# Example: VPNGATE_COUNTRY_SHORT=JP
VPNGATE_COUNTRY=
VPNGATE_COUNTRY_SHORT=

# Optional risk filters (disabled by default; set per-instance when needed)
VPNGATE_RISK_ENABLE=0
VPNGATE_RISK_BLOCK_QUALITY=proxy,datacenter
VPNGATE_RISK_ASN_BLACKLIST=
VPNGATE_RISK_GEOIP_THRESHOLD=70
VPNGATE_RISK_COUNTRY_SCORES=
VPNGATE_RISK_PROXY_SCORE=80
VPNGATE_RISK_DATACENTER_SCORE=60
VPNGATE_RISK_MOBILE_SCORE=20
VPNGATE_RISK_FAIL_OPEN=1
# VPNGATE_RISK_API_URL=http://ip-api.com/batch?fields=status,query,countryCode,proxy,hosting,mobile,as,asname

# Network namespace for this instance (must be unique across parallel instances)
VPN_TUN_DEV=tun0
VPN_ROUTE_TABLE=100
OPENVPN_TEST_DEV=tun

# OpenVPN command + auth file content for VPNGate nodes
OPENVPN_CMD=openvpn
OPENVPN_AUTH_USER=vpn
OPENVPN_AUTH_PASS=vpn

# Optional overrides
# VPNGATE_API_URL=https://www.vpngate.net/api/iphone/
# VPNGATE_DATA_DIR=/opt/aimilivpn/vpngate_data
# For multi-instance mode, set different VPNGATE_DATA_DIR in each instance file.
